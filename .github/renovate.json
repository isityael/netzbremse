{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "local>m0sh1/infra//.github/renovate/base.json",
    "config:best-practices",
    ":preserveSemverRanges"
  ],
  "enabledManagers": [
    "gomod",
    "npm",
    "dockerfile",
    "github-actions",
    "woodpecker"
  ],
  "lockFileMaintenance": {
    "enabled": true,
    "groupName": "lock file maintenance"
  },
  "packageRules": [
    {
      "matchManagers": ["gomod"],
      "addLabels": ["go"],
      "semanticCommitType": "fix",
      "semanticCommitScope": "deps"
    },
    {
      "matchManagers": ["npm"],
      "addLabels": ["npm"],
      "semanticCommitType": "fix",
      "semanticCommitScope": "deps"
    },
    {
      "matchManagers": ["dockerfile"],
      "addLabels": ["docker"],
      "semanticCommitType": "fix",
      "semanticCommitScope": "deps"
    },
    {
      "matchManagers": ["woodpecker"],
      "addLabels": ["docker"],
      "semanticCommitType": "ci",
      "semanticCommitScope": "deps"
    },
    {
      "matchManagers": ["github-actions"],
      "addLabels": ["ci"]
    },
    {
      "description": "Group semantic-release tooling",
      "matchPackageNames": ["/semantic-release/"],
      "groupName": "semantic-release"
    },
    {
      "description": "Group all GitHub Actions into a single PR",
      "matchManagers": ["github-actions"],
      "groupName": "github actions"
    },
    {
      "description": "Auto-merge patch and minor Go module updates — CI-verified",
      "matchManagers": ["gomod"],
      "matchUpdateTypes": ["patch", "minor"],
      "automerge": true
    },
    {
      "description": "Auto-merge GitHub Actions updates",
      "matchManagers": ["github-actions"],
      "automerge": true
    },
    {
      "description": "Group lockfile-only refreshes for package managers where package.json ranges already allow newer versions",
      "matchUpdateTypes": ["lockFileMaintenance"],
      "groupName": "lock file maintenance"
    }
  ]
}
